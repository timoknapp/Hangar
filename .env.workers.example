# =============================================================================
# Unified Hangar Platform Configuration
# Copy to .env.workers and customize before running:
#   ./deploy.sh up
#
# Repo-to-worker assignments live in repos.json (not here).
# Worker ports are auto-assigned by deploy.sh (override with TTYD_PORT_WN / SSH_PORT_WN).
# =============================================================================

# --- GitHub App Authentication ---
GH_APP_ID=
GH_APP_INSTALL_ID=
GH_APP_PEM_FILE=/path/to/gh-app-private-key.pem

# --- Worker Settings ---
POLL_INTERVAL=60

# --- Worker Network Binding ---
# Default: loopback only. Set to 0.0.0.0 to expose on all interfaces.
BIND_ADDRESS=127.0.0.1

# --- Trusted Interactive Hangar Service ---
# This service is part of the hangar-fleet Compose project but intentionally
# keeps a different trust boundary from autonomous workers.
INTERACTIVE_REPO_URL=
INTERACTIVE_REPO_BRANCH=main
INTERACTIVE_WORKSPACE_NAME=repo
INTERACTIVE_EXTRA_REPOS=
INTERACTIVE_BIND_ADDRESS=127.0.0.1
INTERACTIVE_TTYD_PORT=7681
INTERACTIVE_SSH_PORT=2222
INTERACTIVE_PREVIEW_PORT=4173
INTERACTIVE_ENABLE_TTYD=false
INTERACTIVE_AUTO_UPDATE_CLI=false
# Stable prefix preserves interactive data when upgrading from the split-stack v0.1 layout.
INTERACTIVE_VOLUME_PREFIX=hangar

# --- Worker CLI Auto-Update (default: false — use pinned build-time versions) ---
AUTO_UPDATE_CLI=false

# --- Copilot Authentication ---
# User-owned fine-grained PAT from an account with a Copilot license.
# Required account permission: Copilot Requests. Do NOT grant Contents, Issues,
# Pull Requests, or other repository permissions; the GitHub App publisher owns
# those operations and the implementation shell must not inherit them.
# Create at: GitHub > Settings > Developer settings > Fine-grained personal access tokens
COPILOT_PAT=github_pat_...

# --- Worker TTYD Web Terminals (disabled by default) ---
ENABLE_TTYD=false

# --- Worker SSH Access (paste your public key here) ---
SSH_AUTHORIZED_KEY=ssh-ed25519 AAAA... your-key-comment
