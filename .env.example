# =============================================================================
# Interactive Hangar Session Configuration
# Copy to .env and customize before running:
#   docker compose up -d
# =============================================================================

# --- Repository (optional — clone on first start) ---
REPO_URL=
REPO_BRANCH=main

# --- Workspace name (used to derive container path /workspace/<name>) ---
WORKSPACE_NAME=repo

# --- Extra repos to clone (comma-separated: "url#branch,url#branch") ---
EXTRA_REPOS=

# --- Network Binding ---
# Default: loopback only. Set to 0.0.0.0 to expose on all interfaces.
BIND_ADDRESS=127.0.0.1

# --- Ports ---
TTYD_PORT=7681
SSH_PORT=2222
PREVIEW_PORT=4173

# --- TTYD Web Terminal (disabled by default) ---
ENABLE_TTYD=false

# --- CLI Auto-Update (default: false — use pinned build-time versions) ---
AUTO_UPDATE_CLI=false
