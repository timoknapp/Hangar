# =============================================================================
# Squad Worker Fleet Configuration
# Copy to .env.workers and customize before running:
#   ./deploy.sh up
#
# Repo-to-worker assignments live in repos.json (not here).
# Ports are auto-assigned by deploy.sh (override with TTYD_PORT_WN / SSH_PORT_WN).
# =============================================================================

# --- GitHub App Authentication ---
GH_APP_ID=
GH_APP_INSTALL_ID=
GH_APP_PEM_FILE=/path/to/gh-app-private-key.pem

# --- Worker Settings ---
POLL_INTERVAL=60

# --- Network Binding ---
# Default: loopback only. Set to 0.0.0.0 to expose on all interfaces.
BIND_ADDRESS=127.0.0.1

# --- CLI Auto-Update (default: false — use pinned build-time versions) ---
AUTO_UPDATE_CLI=false

# --- Copilot Authentication ---
# User-owned fine-grained PAT from an account with a Copilot license.
# Required account permission: Copilot Requests. Do NOT grant Contents, Issues,
# Pull Requests, or other repository permissions; the GitHub App publisher owns
# those operations and the implementation shell must not inherit them.
# Create at: GitHub > Settings > Developer settings > Fine-grained personal access tokens
COPILOT_PAT=github_pat_...

# --- TTYD Web Terminal (disabled by default, set to true to enable) ---
ENABLE_TTYD=false

# --- SSH Access (paste your public key here) ---
SSH_AUTHORIZED_KEY=ssh-ed25519 AAAA... your-key-comment
